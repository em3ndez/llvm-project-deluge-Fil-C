@AMDEP_TRUE@@am__include@ @am__quote@./$(DEPDIR)/enchant-lsmod.Po@am__quote@ # am--include-marker
@AMDEP_TRUE@@am__include@ @am__quote@./$(DEPDIR)/enchant.Po@am__quote@ # am--include-marker

